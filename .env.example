# Chromecast 音量制御の設定

# 制御対象の Chromecast / Google TV 名
CHROMECAST_NAME="Your Chromecast Name"

# 1回の定期実行で下げる音量幅（負の値）
STEP=-0.04

# これ以上は下げない最小音量レベル
MIN_LEVEL=0.3

# スケジューラから呼び出される間隔（秒）
INTERVAL_SEC=1200

# 手動で音量が上げられない状態が何回続いたら standby にするか
INACTIVE_THRESHOLD=3

# 手動で音量が上がったと判定する最小差分
MANUAL_RISE_THRESHOLD=0.01

# 活動判定用 state JSON の保存先
STATE_FILE="logs/activity_state.json"

# state を古いとみなす倍率。実際の猶予秒数は INTERVAL_SEC x この値
STATE_STALE_INTERVAL_MULTIPLIER=2

# standby になるまで interval ごとに繰り返し実行するか
RUN_UNTIL_STANDBY=0

# 20:00 用プロファイル
CRON_20_NAME="Your Chromecast Name"
CRON_20_INTERVAL_SEC=60
CRON_20_INACTIVE_THRESHOLD=1
CRON_20_STEP=-0.04
CRON_20_MIN_LEVEL=0.05
CRON_20_STATE_FILE="logs/activity_state_20.json"

# 00:30 用プロファイル
CRON_0030_NAME="Your Chromecast Name"
CRON_0030_INTERVAL_SEC=900
CRON_0030_INACTIVE_THRESHOLD=4
CRON_0030_STEP=-0.04
CRON_0030_MIN_LEVEL=0.35
CRON_0030_STATE_FILE="logs/activity_state_0030.json"
